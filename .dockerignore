.git
.github
.vscode

# Docker image builds only need backend, frontend, scripts, docs/terms,
# and deploy/all-in-one. Keep offline model and desktop artifacts out of
# the build context; these can be tens of GB on packaging machines.
deploy/*
!deploy/all-in-one
!deploy/all-in-one/**
desktop-electron
dist

docs/*
!docs/terms
!docs/terms/**
desktop

backend/uploads
backend/configs/config.yaml
backend/cmd/**/__debug_bin*

frontend/node_modules
frontend/dist
frontend/.vite
frontend/.env
frontend/.env.*

deploy/all-in-one/dist

**/node_modules
**/dist
**/.vite
**/target
**/*.tsbuildinfo
**/*.log
**/__pycache__