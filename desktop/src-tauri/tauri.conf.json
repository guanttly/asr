{
  "$schema": "../node_modules/.pnpm/@tauri-apps+cli@2.10.1/node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "巨鲨语音助手",
  "identifier": "com.asr.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "巨鲨语音助手",
        "width": 132,
        "height": 132,
        "minWidth": 132,
        "minHeight": 132,
        "maxWidth": 132,
        "maxHeight": 132,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": [
          "English",
          "SimpChinese"
        ],
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
