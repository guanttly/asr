VITE_DEV_HTTPS=true
# Optional: provide your own certificate files instead of Vite basic SSL.
# VITE_DEV_HTTPS_CERT=certs/dev-cert.pem
# VITE_DEV_HTTPS_KEY=certs/dev-key.pem

# Optional: override API/WS base URLs in production builds.
# VITE_API_BASE_URL=https://your-domain.example
# VITE_WS_BASE_URL=wss://your-domain.example