{
  "name": "asr-frontend",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "ASR_REAL_SMOKE=1 playwright test tests/e2e/real-server-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@vueuse/core": "^13.0.0",
    "axios": "^1.9.0",
    "markdown-it": "^14.1.1",
    "naive-ui": "^2.42.0",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@playwright/test": "1.56.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.14.0",
    "@unocss/preset-attributify": "^66.1.0",
    "@unocss/preset-uno": "^66.1.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^9.23.0",
    "typescript": "~5.8.3",
    "unocss": "^66.1.0",
    "unplugin-auto-import": "^19.1.1",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.8"
  }
}
