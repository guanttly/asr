.git
.github
.vscode

# Docker image builds only need backend sources, frontend sources,
# scripts/build-meta.ts, docs/terms, and a small whitelist from
# deploy/jusha-asr-business. Keep release bundles and runtime state out of the
# build context so packaging hosts do not upload multi-GB history.
deploy/*
!deploy/jusha-asr-business/
deploy/jusha-asr-business/*
!deploy/jusha-asr-business/Dockerfile
!deploy/jusha-asr-business/README.md
!deploy/jusha-asr-business/docker-compose.yml
!deploy/jusha-asr-business/docker-compose.bundle.yml
!deploy/jusha-asr-business/nginx.conf
!deploy/jusha-asr-business/supervisord.conf
!deploy/jusha-asr-business/scripts/
!deploy/jusha-asr-business/scripts/**
desktop-electron
dist
runtime

docs/*
!docs/terms
!docs/terms/**

desktop

backend/admin-api
backend/runtime
backend/uploads
backend/configs/config.yaml
backend/cmd/**/__debug_bin*

frontend/node_modules
frontend/dist
frontend/.vite
frontend/.env
frontend/.env.*
frontend/test-results

**/node_modules
**/dist
**/.vite
**/target
**/*.tsbuildinfo
**/*.log
**/__pycache__